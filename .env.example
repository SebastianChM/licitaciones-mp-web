# Copiar a .env y completar. El .env real JAMÁS se commitea (P10 de CLAUDE.md).

# Clave secreta de Django (generar una real para producción)
LICITAWEB_SECRET_KEY=

# true en desarrollo, false en producción
LICITAWEB_DEBUG=true

# Hosts permitidos, separados por coma
LICITAWEB_ALLOWED_HOSTS=localhost,127.0.0.1

# Ticket de la API pública de Mercado Público (solicitar en api.mercadopublico.cl)
# Solo necesario para los comandos `enriquecer` y `sincronizar_estados` (M4).
LICITAWEB_MERCADO_PUBLICO_TICKET=
